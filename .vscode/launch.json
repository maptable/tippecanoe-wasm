{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug tippecanoe",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/tippecanoe",
      "args": [
        "-zg",
        "-Z1",
        "-Bg",
        "--force",
        "--smallest-maximum-zoom-guess=12",
        "--preserve-point-density-threshold=4096",
        "--drop-densest-as-needed",
        "--reorder",
        "--extend-zooms-if-still-dropping",
        "-o",
        "build/test.mbtiles",
        "build/test.geojson"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "TIPPECANOE_MAX_THREADS",
          "value": "1"
        },
        {
          "name": "TIPPECANOE_NO_THREADS",
          "value": "1"
        }
      ],
      "externalConsole": false,
      "MIMode": "lldb",
      "preLaunchTask": "build-debug"
    }
  ]
}
